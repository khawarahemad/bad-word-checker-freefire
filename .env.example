# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Free Fire JWT Token (captured from game API traffic)
FF_JWT_TOKEN=your_freefire_jwt_token_here

# Free Fire version headers — UPDATE THESE with each OB patch!
# Find the latest values by sniffing game traffic with HTTP Toolkit / Charles Proxy
FF_UNITY_VERSION=2018.4.11f1
FF_GA_VERSION=v1 1
FF_RELEASE_VERSION=OB50
